PORT=5000
CLIENT_URL=http://localhost:5174

# JWT Secret (change this to a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Admin credentials (used to seed the DB on first run)
ADMIN_EMAIL=admin@hexagonview.com
ADMIN_PASSWORD=Admin@Hexagon2024

# Nodemailer — SMTP settings to send email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Email that receives notifications for new inquiries
NOTIFY_EMAIL=info@hexagonview.com
